# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLOUDFLARE TURNSTILE VARIABLES
# Site Key used by the Frontend client. (Standard always-passes testing key is 1x00000000000000000000AA)
VITE_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# Secret Key used by the Backend server. (Standard always-passes testing key is 1x00000000000000000000000000000000AA)
TURNSTILE_SECRET_KEY="1x00000000000000000000000000000000AA"

# ==========================================
# HUBSPOT — Formulario de contacto
# ==========================================
# 1. Entra a tu cuenta de HubSpot (o crea una gratis en hubspot.com si no tienes).
# 2. Ve a: Marketing > Forms (o Formularios) > Create form > "Formulario independiente".
# 3. Agrega los campos: firstname, email, company, phone, city, y crea 2 campos
#    personalizados de texto de una línea llamados "servicio" y "presupuesto".
# 4. Guarda el formulario, luego ábrelo y ve a la pestaña "Compartir" o mira la URL
#    de edición: hubspot.com/.../forms/editor/<HUBSPOT_PORTAL_ID>/editor/<HUBSPOT_FORM_GUID>
#    - El número justo antes de "/editor" (o en tu URL de cuenta arriba a la derecha,
#      "Hub ID") es el HUBSPOT_PORTAL_ID.
#    - El código largo tipo UUID es el HUBSPOT_FORM_GUID.
# 5. En el formulario, en "Opciones" > "Notificaciones de formulario", agrega
#    informacion.destec@gmail.com como destinatario para recibir cada lead por correo.
# 6. Pega aquí ambos valores:
HUBSPOT_PORTAL_ID="TU_PORTAL_ID_AQUI"
HUBSPOT_FORM_GUID="TU_FORM_GUID_AQUI"

